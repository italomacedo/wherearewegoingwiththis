{
  "name": "where-are-we-going-with-this",
  "version": "0.1.0",
  "description": "BeiraRio Games | Cyberpunk Isometric Open-World RPG",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "copy:havok": "node scripts/copy-havok-wasm.mjs",
    "copy:kokoro": "node scripts/copy-kokoro-model.mjs",
    "copy:assets": "npm run copy:havok && npm run copy:kokoro",
    "predev": "npm run copy:assets",
    "dev": "vite",
    "prebuild": "npm run copy:assets",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "preelectron:dev": "npm run copy:assets",
    "electron:dev": "vite",
    "electron:build": "npm run build && electron-builder",
    "scrub": "vite --config vite.scrub.config.ts --port 5174",
    "test": "jest",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "lint": "eslint src electron --ext .ts,.tsx",
    "lint:fix": "eslint src electron --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.electron.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@babylonjs/core": "^7.35.0",
    "@babylonjs/gui": "^7.35.0",
    "@babylonjs/havok": "^1.3.10",
    "@babylonjs/inspector": "^7.35.0",
    "@babylonjs/loaders": "^7.35.0",
    "@babylonjs/materials": "^7.35.0",
    "electron-store": "^10.0.0",
    "kokoro-js": "^1.2.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "babel-jest": "^30.4.1",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.15.0",
    "ffmpeg-static": "^5.3.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.2",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.beiiriogames.wherearewegoingwiththis",
    "productName": "Where Are We Going With This",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    }
  }
}
